generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum ItemStatus {
  PENDING
  QUESTION_SENT
  ANSWER_SHOWN
  CORRECT
  INCORRECT
}

enum ReviewActionType {
  SENT
  ANSWER_SHOWN
  GREAT_CORRECT
  CORRECT
  INCORRECT
}

enum ConversationStateType {
  QUESTION_SENT
  ANSWER_SHOWN
}

enum ProductStudyImageKind {
  QUESTION
  ANSWER
}

enum GeminiApiCallStatus {
  SUCCESS
  FAILED
}

enum LineApiCallKind {
  PUSH
  REPLY
  PROFILE
}

enum LineApiCallStatus {
  SUCCESS
  FAILED
}

model User {
  id                       Int                       @id @default(autoincrement())
  lineUserId               String?                   @unique
  displayName              String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  studyItems               ProductStudyItem[]
  reviewLogs               ReviewLog[]
  activeConversationStates ActiveConversationState[]
  geminiApiCallLogs        GeminiApiCallLog[]
  lineApiCallLogs          LineApiCallLog[]
}

model ProductStudyItem {
  id                  Int                       @id @default(autoincrement())
  userId              Int
  questionNumber      Int                       @unique
  autoSendEnabled     Boolean                   @default(true)
  isFavorite          Boolean                   @default(false)
  deletedAt           DateTime?
  productName         String?
  brandName           String?
  category            String?
  note                String                    @default("")
  memo                String?
  firstScheduledAt    DateTime
  nextScheduledAt     DateTime
  status              ItemStatus                @default(PENDING)
  summary             String
  question            String
  answer              String
  explanation         String
  difficulty          String
  tags                Json
  keyPoints           Json
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  images              ProductStudyImage[]
  reviewLogs          ReviewLog[]
  activeConversations ActiveConversationState[]
  lineApiCallLogs     LineApiCallLog[]

  @@index([nextScheduledAt])
  @@index([status])
  @@index([userId])
}

model ProductStudyImage {
  id        Int              @id @default(autoincrement())
  itemId    Int
  kind      ProductStudyImageKind @default(QUESTION)
  imagePath String
  sortOrder Int
  createdAt DateTime         @default(now())
  item      ProductStudyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model ReviewLog {
  id         Int              @id @default(autoincrement())
  itemId     Int
  userId     Int
  actionType ReviewActionType
  actionAt   DateTime         @default(now())
  rawText    String?
  createdAt  DateTime         @default(now())
  item       ProductStudyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId, actionAt])
  @@index([userId, actionAt])
}

model ActiveConversationState {
  id                    Int                   @id @default(autoincrement())
  userId                Int
  itemId                Int
  state                 ConversationStateType
  questionLineMessageId String?               @unique
  questionLineMessageIds String[]             @default([])
  answerLineMessageId   String?               @unique
  answerLineMessageIds  String[]              @default([])
  updatedAt             DateTime              @updatedAt
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item                  ProductStudyItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([userId])
  @@unique([userId, itemId])
}

model GeminiApiCallLog {
  id             Int                 @id @default(autoincrement())
  userId         Int?
  status         GeminiApiCallStatus
  model          String
  promptLength   Int
  imageCount     Int
  responseLength Int?
  errorMessage   String?
  createdAt      DateTime            @default(now())
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model LineApiCallLog {
  id                   Int               @id @default(autoincrement())
  userId               Int?
  itemId               Int?
  kind                 LineApiCallKind
  status               LineApiCallStatus
  targetLineUserId     String?
  messageCount         Int               @default(0)
  estimatedBillableCount Int             @default(0)
  errorMessage         String?
  createdAt            DateTime          @default(now())
  user                 User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  item                 ProductStudyItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([kind, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([itemId, createdAt])
}
