generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

enum ItemStatus {
  PENDING
  QUESTION_SENT
  ANSWER_SHOWN
  CORRECT
  INCORRECT
}

enum ReviewActionType {
  SENT
  ANSWER_SHOWN
  CORRECT
  INCORRECT
}

enum ConversationStateType {
  QUESTION_SENT
  ANSWER_SHOWN
}

model User {
  id                      Int                      @id @default(autoincrement())
  lineUserId              String?                  @unique
  displayName             String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  studyItems              ProductStudyItem[]
  reviewLogs              ReviewLog[]
  activeConversationState ActiveConversationState?
}

model ProductStudyItem {
  id                  Int                       @id @default(autoincrement())
  userId              Int
  questionNumber      Int                       @unique
  autoSendEnabled     Boolean                   @default(true)
  deletedAt           DateTime?
  productName         String?
  brandName           String?
  category            String?
  note                String                    @default("")
  memo                String?
  firstScheduledAt    DateTime
  nextScheduledAt     DateTime
  status              ItemStatus                @default(PENDING)
  summary             String
  question            String
  answer              String
  explanation         String
  difficulty          String
  tags                Json
  keyPoints           Json
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  images              ProductStudyImage[]
  reviewLogs          ReviewLog[]
  activeConversations ActiveConversationState[]

  @@index([nextScheduledAt])
  @@index([status])
  @@index([userId])
}

model ProductStudyImage {
  id        Int              @id @default(autoincrement())
  itemId    Int
  imagePath String
  sortOrder Int
  createdAt DateTime         @default(now())
  item      ProductStudyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model ReviewLog {
  id         Int              @id @default(autoincrement())
  itemId     Int
  userId     Int
  actionType ReviewActionType
  actionAt   DateTime         @default(now())
  rawText    String?
  createdAt  DateTime         @default(now())
  item       ProductStudyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId, actionAt])
  @@index([userId, actionAt])
}

model ActiveConversationState {
  id        Int                   @id @default(autoincrement())
  userId    Int                   @unique
  itemId    Int
  state     ConversationStateType
  updatedAt DateTime              @updatedAt
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      ProductStudyItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}
